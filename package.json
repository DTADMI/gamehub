{
  "name": "gamehub",
  "version": "1.0.0",
  "private": true,
  "description": "GameHub - Next.js frontend + NestJS backend monorepo",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@gamehub/frontend",
    "dev:api": "turbo run dev --filter=@gamehub/api",
    "build": "turbo run build",
    "build:frontend": "turbo run build --filter=@gamehub/frontend",
    "build:api": "turbo run build --filter=@gamehub/api",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=@gamehub/frontend",
    "test:watch": "turbo run test:watch",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:turbo": "rm -rf .turbo",
    "prepare": "husky || true",
    "prisma:generate": "turbo run prisma:generate --filter=@gamehub/api",
    "prisma:migrate": "pnpm --filter @gamehub/api prisma:migrate",
    "prisma:studio": "pnpm --filter @gamehub/api prisma:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@scarf/scarf": "1.4.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.7.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3",
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "typescript": "^5.9.3",
      "mime": "^3.0.0",
      "glob-parent": "^6.0.2",
      "json5": "^2.2.3",
      "yargs-parser": "^21.1.1",
      "node-forge": "^1.3.1",
      "@scarf/scarf": "1.4.0"
    },
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/engines",
      "@swc/core",
      "sharp",
      "unrs-resolver"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [
        "@types/node"
      ],
      "allowedVersions": {
        "react": "19.0.0",
        "react-dom": "19.0.0"
      }
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@scarf/scarf",
      "@swc/core",
      "bcrypt",
      "esbuild",
      "prisma",
      "sharp",
      "supabase",
      "unrs-resolver"
    ]
  }
}
