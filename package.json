{
  "name": "gamehub",
  "version": "0.1.0",
  "private": true,
  "description": "GameHub - Next.js portfolio + game platform",
  "engines": {
    "node": ">=24 <26",
    "pnpm": ">=10.26.0"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:all": "pnpm type-check && pnpm test:unit && pnpm test:integration && pnpm test:e2e:smoke",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests-e2e/smoke.spec.ts --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "check:deps": "knip --include dependencies,unlisted,binaries",
    "check:deps:strict": "knip --strict",
    "check:env": "node scripts/validate-env.mjs",
    "ci:local": "pnpm guard:lockfile && pnpm lint && pnpm type-check && pnpm test:unit && pnpm test:integration && pnpm build && pnpm test:e2e:smoke",
    "audit:outdated": "node scripts/run-outdated-audit.mjs",
    "audit:deps:graph": "node scripts/export-dependency-graph.mjs",
    "audit:module-replacements": "node scripts/module-replacements-audit.mjs",
    "audit:e18e": "node scripts/run-e18e-audit.mjs",
    "audit:all": "pnpm audit:outdated && pnpm audit:deps:graph && pnpm audit:module-replacements && pnpm audit:e18e && pnpm check:deps",
    "guard:lockfile": "pnpm install --frozen-lockfile --ignore-scripts",
    "guard:precommit": "pnpm guard:lockfile && pnpm build",
    "lockfile:sync": "pnpm install",
    "smoke": "node scripts/smoke-test.mjs",
    "clean": "rimraf .next out coverage test-results playwright-report"
  },
  "dependencies": {
    "@gamehub/game-platform": "workspace:*",
    "@gamehub/ui": "workspace:*",
    "@games/breakout": "workspace:*",
    "@games/checkers": "workspace:*",
    "@games/chess": "workspace:*",
    "@games/memory": "workspace:*",
    "@games/platformer": "workspace:*",
    "@games/snake": "workspace:*",
    "@games/tetris": "workspace:*",
    "@games/tower-defense": "workspace:*",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-query": "^5.96.0",
    "@tiptap/extension-link": "^3.22.0",
    "@tiptap/extension-placeholder": "^3.22.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^0.562.0",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "knip": "^5.69.2",
    "postcss": "^8.5.8",
    "postcss-load-config": "^6.0.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
