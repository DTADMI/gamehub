{
  "name": "gamehub",
  "version": "0.1.0",
  "private": true,
  "description": "GameHub - Next.js portfolio + game platform",
  "engines": {
    "node": "^20.20.0 || ^22.22.0 || ^24.13.0 || ^25.3.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:all": "pnpm type-check && pnpm test:unit && pnpm test:integration && pnpm test:e2e:smoke",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests-e2e/smoke.spec.ts --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "clean": "rimraf .next out coverage test-results playwright-report"
  },
  "dependencies": {
    "@gamehub/game-platform": "workspace:*",
    "@gamehub/ui": "workspace:*",
    "@games/breakout": "workspace:*",
    "@games/checkers": "workspace:*",
    "@games/chess": "workspace:*",
    "@games/memory": "workspace:*",
    "@games/platformer": "workspace:*",
    "@games/snake": "workspace:*",
    "@games/tetris": "workspace:*",
    "@games/tower-defense": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.4",
    "@tiptap/extension-link": "^3.7.3",
    "@tiptap/extension-placeholder": "^3.7.3",
    "@tiptap/react": "^3.7.3",
    "@tiptap/starter-kit": "^3.7.3",
    "@vercel/analytics": "^1.6.1",
    "@upstash/redis": "^1.35.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.70.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "rimraf": "^6.1.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
