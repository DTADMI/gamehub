{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@gamehub/game-platform": [
        "packages/game-platform/src"
      ],
      "@gamehub/game-platform/*": [
        "packages/game-platform/src/*"
      ],
      "@games/pointclick-engine": [
        "packages/pointclick-engine/src"
      ],
      "@games/pointclick-engine/*": [
        "packages/pointclick-engine/src/*"
      ],
      "@games/_engine": [
        "packages/games/_engine"
      ],
      "@games/*": [
        "packages/games/*/src"
      ],
      "react": [
        "./node_modules/@types/react"
      ],
      "react/*": [
        "./node_modules/@types/react/*"
      ],
      "react-dom": [
        "./node_modules/@types/react-dom"
      ],
      "react-dom/*": [
        "./node_modules/@types/react-dom/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "typeRoots": [
      "./node_modules/@types"
    ],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "packages/game-platform/**/*.ts",
    "packages/game-platform/**/*.tsx",
    "packages/ui/**/*.ts",
    "packages/ui/**/*.tsx",
    "packages/games/**/*.ts",
    "packages/games/**/*.tsx",
    "packages/pointclick-engine/**/*.ts",
    "packages/pointclick-engine/**/*.tsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "packages/**/node_modules",
    "packages/**/dist",
    "packages/games/breakout/src/app",
    "**/*.md",
    "**/*.mdx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/jest.setup.ts",
    "**/__tests__/**"
  ]
}
