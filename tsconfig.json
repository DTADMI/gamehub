{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@games/shared": ["packages/game-platform/src"],
      "@games/shared/*": ["packages/game-platform/src/*"],
      "@games/_engine": ["packages/games/_engine"],
      "@games/*": ["packages/games/*/src"]
    },
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "packages/game-platform/**/*.ts",
    "packages/game-platform/**/*.tsx",
    "packages/ui/**/*.ts",
    "packages/ui/**/*.tsx",
    "packages/games/**/*.ts",
    "packages/games/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "packages/**/node_modules",
    "packages/**/dist",
    "packages/games/breakout/src/app",
    "**/*.md",
    "**/*.mdx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/jest.setup.ts",
    "**/__tests__/**"
  ]
}
