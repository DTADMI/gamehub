{
  "name": "@gamehub/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "GameHub Next.js Frontend Application",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "clean": "rimraf .next out coverage test-results playwright-report"
  },
  "dependencies": {
    "@games/breakout": "workspace:*",
    "@games/checkers": "workspace:*",
    "@games/chess": "workspace:*",
    "@games/memory": "workspace:*",
    "@games/platformer": "workspace:*",
    "@games/shared": "workspace:*",
    "@games/snake": "workspace:*",
    "@games/tetris": "workspace:*",
    "@games/tower-defense": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@vercel/analytics": "^1.6.1",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.1",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.70.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
