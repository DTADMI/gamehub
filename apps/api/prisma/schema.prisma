generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  username  String?  @unique
  name      String?
  avatar    String?
  image     String?  // StoryForge/LibraKeeper compatibility
  password  String?  // LibraKeeper compatibility
  passwordHash String? // StoryForge compatibility
  bio       String?
  website   String?
  settings  Json?    @default("{}")
  role      Role     @default(USER)
  emailVerified DateTime?
  
  // Project Access (Feature Flags/Permissions)
  allowedProjects String[] @default([]) // List of project slugs the user can access
  isAdmin         Boolean  @default(false)

  subscriptionStatus   String?
  subscriptionExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  stats     GameStat[]
  comments  Comment[]
  
  // LibraKeeper
  accounts      Account[]
  sessions      Session[]
  loans         Loan[]
  lk_comments   LK_Comment[]
  lk_likes      LK_Like[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  itemRequests  ItemRequest[] @relation("RequestedItems")
  waitlistItems WaitlistEntry[]
  lk_settings   AppSettings[]

  // StoryForge
  sf_projects      SF_Project[]
  inkPot        InkPot?
  inkTx         InkTx[]
  goals         Goal[]
  progressLog   ProgressLog[]
  badges        UserBadge[]
  followers     Follow[] @relation("followers")
  following     Follow[] @relation("following")
  groups        GroupMember[]
  characters    Character[]
  locations     Location[]
  timelineEvents TimelineEvent[]

  // QuestHunt
  searchHistory SearchHistory[]

  // Access Control
  projectAccess UserProjectAccess[]
  purchases     ProjectPurchase[]
}

enum Role {
  USER
  ADMIN
}

enum AccessTier {
  FREE
  FREEMIUM
  PREMIUM
  ENTERPRISE
}

enum PurchaseType {
  SINGLE
  MONTHLY
  YEARLY
  BUNDLE
  LIFETIME
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

// --- GameHub Original Models ---

model GameStat {
  id        String   @id @default(uuid())
  gameId    String
  userId    String
  score     Int      @default(0)
  highScore Int      @default(0)
  playedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, gameId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  gameId    String
  userId    String
  rating    Int?     // 1-5
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// --- LibraKeeper Models ---

model AppSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      SettingType @default(STRING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String?
  user      User?    @relation(fields: [updatedBy], references: [id])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isEnabled   Boolean  @default(false)
  
  // Specific targets
  gameSlug    String?  // If flag applies to a specific game
  projectSlug String?  // If flag applies to a specific project
  
  // Visibility status
  status      String?  @default("visible") // "visible", "featured", "coming-soon", "hidden"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum SettingType {
  STRING
  BOOLEAN
  NUMBER
  JSON
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Item {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        ItemType
  status      ItemStatus @default(AVAILABLE)
  coverImage  String?
  isbn        String?
  author      String?
  publisher   String?
  publishedAt DateTime?
  metadata    Json?      @default("{}")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tags        Tag[]      @relation("ItemTags")
  loans       Loan[]
  comments    LK_Comment[]
  likes       LK_Like[]
}

enum ItemType {
  BOOK
  ELECTRONIC
  TOOL
  OTHER
}

enum ItemStatus {
  AVAILABLE
  LOANED
  MAINTENANCE
  LOST
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  items Item[] @relation("ItemTags")
}

model Loan {
  id         String    @id @default(cuid())
  itemId     String
  userId     String
  loanDate   DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     LoanStatus @default(ACTIVE)
  notes      String?
  item       Item      @relation(fields: [itemId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

model LK_Comment {
  id        String   @id @default(cuid())
  content   String
  itemId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LK_Like {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model Message {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  receiverId String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model ItemRequest {
  id          String        @id @default(cuid())
  userId      String
  title       String
  description String?
  status      RequestStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation("RequestedItems", fields: [userId], references: [id])
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, itemId])
}

// --- StoryForge Models ---

enum VisibilityScope {
  PRIVATE
  FRIENDS
  PUBLIC_AUTHENTICATED
  PUBLIC_ANYONE
}

model SF_Project {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  title         String
  description   String?
  content       String?  @db.Text
  genre         String?
  isPublic      Boolean  @default(false)
  wordCount     Int      @default(0)
  defaultScope  VisibilityScope @default(PRIVATE)
  settings      Json?

  characters    Character[]
  locations     Location[]
  timelineEvents TimelineEvent[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InkPot {
  id      String @id @default(cuid())
  user    User   @relation(fields: [userId], references: [id])
  userId  String @unique
  balance Int    @default(0)

  transactions InkTx[]
}

model InkTx {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  pot       InkPot?  @relation(fields: [potId], references: [id])
  potId     String?
  amount    Int
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Goal {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  type      String   // e.g., 'words_per_day'
  target    Int      // e.g., 500
  cadence   String   // 'daily' | 'weekly'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  progress  ProgressLog[]
}

model ProgressLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  goal      Goal?    @relation(fields: [goalId], references: [id])
  goalId    String?
  value     Int
  unit      String   @default("words")
  timestamp DateTime @default(now())
}

model UserBadge {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  badge     Badge    @relation(fields: [badgeId], references: [id])
}

model Badge {
  id          String      @id @default(cuid())
  name        String
  description String
  imageUrl    String
  userBadges  UserBadge[]
}

model Follow {
  follower    User   @relation("following", fields: [followerId], references: [id])
  followerId  String
  following   User   @relation("followers", fields: [followingId], references: [id])
  followingId String

  @@id([followerId, followingId])
}

model Group {
  id          String        @id @default(cuid())
  name        String
  description String?
  members     GroupMember[]
  createdAt   DateTime      @default(now())
}

model GroupMember {
  id      String @id @default(cuid())
  group   Group  @relation(fields: [groupId], references: [id])
  groupId String
  user    User   @relation(fields: [userId], references: [id])
  userId  String
  role    String @default("MEMBER")
}

model Character {
  id          String      @id @default(cuid())
  project     SF_Project? @relation(fields: [projectId], references: [id])
  projectId   String?
  user        User?       @relation(fields: [userId], references: [id])
  userId      String?
  name        String
  description String?
  avatarUrl   String?
  metadata    Json?
}

model Location {
  id          String      @id @default(cuid())
  project     SF_Project? @relation(fields: [projectId], references: [id])
  projectId   String?
  user        User?       @relation(fields: [userId], references: [id])
  userId      String?
  name        String
  description String?
  imageUrl    String?
  metadata    Json?
}

model TimelineEvent {
  id          String      @id @default(cuid())
  project     SF_Project? @relation(fields: [projectId], references: [id])
  projectId   String?
  user        User?       @relation(fields: [userId], references: [id])
  userId      String?
  title       String
  description String?
  timestamp   DateTime
}

// --- QuestHunt Models ---

model SearchQuery {
  id        String   @id @default(cuid())
  query     String   @unique
  count     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([query])
}

model SearchHistory {
  id             String   @id @default(cuid())
  userId         String
  query          String
  searchCount    Int      @default(1)
  lastSearchedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, query])
  @@index([userId])
  @@index([query])
}

// --- Access Control Models ---

model UserProjectAccess {
  id        String     @id @default(cuid())
  userId    String
  projectId String     // Slug: 'libra-keeper', 'quest-hunt', 'story-forge'
  tier      AccessTier
  grantedAt DateTime   @default(now())
  expiresAt DateTime?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model ProjectPurchase {
  id              String         @id @default(cuid())
  userId          String
  projectId       String         // Slug: 'libra-keeper', 'quest-hunt', 'story-forge'
  purchaseType    PurchaseType
  amount          Decimal        @db.Decimal(10, 2)
  currency        String         @default("USD")
  stripeSessionId String?        @unique
  stripePaymentId String?
  status          PurchaseStatus
  metadata        Json?          @default("{}")
  purchasedAt     DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([stripeSessionId])
  @@index([status])
}
