{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "moduleResolution": "bundler",
    "strict": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@games/shared": ["./src/index.ts"],
      "@games/shared/*": ["./src/*"],
      "@games/*": ["../games/*/src"],
      "@projects/*": ["../projects/*"],
      "@shared/*": ["../shared/src/*"],
      "@ui/*": ["../../packages/ui/src/*"],
      "@ui": ["../../packages/ui/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
